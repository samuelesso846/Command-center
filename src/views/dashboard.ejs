async function saveClient() {
  const name = document.getElementById('cnName').value;
  if (!name) { toast('Entrez le nom', 'warning'); return; }
  try {
    await fetch('/api/clients', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        name, phone: document.getElementById('cnPhone').value,
