// ═══ MODE PRÉDICTION ═══
function runSimulation() {
  const clients = parseInt(document.getElementById('simClients')?.value)||3;
  const revClient = parseInt(document.getElementById('simRevClient')?.value)||150000;
  const croissance = parseInt(document.getElementById('simCroissance')?.value)||20;
  const depenses = parseInt(document.getElementById('simDepenses')?.value)||50000;
  const revMois = clients * revClient;
  const marge = revMois - depenses;
  const rev3m = Math.round(revMois * (Math.pow(1+croissance/100,3)-1)/(croissance/100) * revMois);
  const rev6m = Math.round(revMois * (Math.pow(1+croissance/100,6)-1)/(croissance/100) * revMois);
  if (document.getElementById('pred3m')) document.getElementById('pred3m').textContent = formatNum(rev3m);
  if (document.getElementById('pred6m')) document.getElementById('pred6m').textContent = formatNum(rev6m);
  const target = 1000000; const monthsNeeded = marge > 0 ? Math.ceil(Math.log(target/revMois)/Math.log(1+croissance/100)) : '∞';
  if (document.getElementById('predTarget')) document.getElementById('predTarget').textContent = monthsNeeded;
  const results = document.getElementById('simResults');
  if (results) results.innerHTML = `
    <div style="padding:14px;background:var(--bg);border-radius:10px">
      <div>Revenu mois 1: <strong>${formatNum(revMois)} FCFA</strong></div>
      <div>Marge nette: <strong style="color:${marge>=0?'var(--success)':'var(--danger)'}">${formatNum(marge)} FCFA</strong></div>
      <div>À ce rythme, 1M FCFA/mois dans: <strong>${monthsNeeded} mois</strong></div>
    </div>`;
}
