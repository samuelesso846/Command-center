let smartGoals = JSON.parse(localStorage.getItem('cc_smart')||'[]');
function addSmartGoal() {
  const obj = document.getElementById('smartObj')?.value;
  if (!obj) { toast('Entrez un objectif','warning'); return; }
  smartGoals.push({id:Date.now(),obj,date:document.getElementById('smartDate')?.value,actions:document.getElementById('smartActions')?.value,done:false});
  localStorage.setItem('cc_smart',JSON.stringify(smartGoals));
  renderSmartGoals(); toast('Objectif ajouté !','success'); addXP(15);
}
function renderSmartGoals() {
  const el = document.getElementById('smartGoals');
  if (!el) return;
  if (!smartGoals.length) { el.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text2)">Aucun objectif</div>'; return; }
  el.innerHTML = smartGoals.map(g=>`<div style="padding:14px;background:var(--bg);border-radius:10px;margin-bottom:10px"><div style="font-weight:700;margin-bottom:4px">${g.obj}</div>${g.date?`<div style="font-size:12px;color:var(--accent)">📅 ${g.date}</div>`:''}<div style="font-size:13px;color:var(--text2);margin-top:6px;white-space:pre-wrap">${g.actions||''}</div><button class="btn btn-danger btn-sm" style="margin-top:8px" onclick="smartGoals=smartGoals.filter(x=>x.id!==${g.id});localStorage.setItem('cc_smart',JSON.stringify(smartGoals));renderSmartGoals()">Supprimer</button></div>`).join('');
}

// ═══ GALERIE ═══
let galerieImages = JSON.parse(localStorage.getItem('cc_galerie')||'[]');
function galerieHandleDrop(e) { e.preventDefault(); galerieHandleFiles(e.dataTransfer.files); }
function galerieHandleFiles(files) {
  Array.from(files).forEach(f => {
    if (!f.type.startsWith('image/')) return;
    const reader = new FileReader();
    reader.onload = e => {
      galerieImages.unshift({id:Date.now()+Math.random(),src:e.target.result,name:f.name,date:new Date().toLocaleDateString('fr-FR')});
      localStorage.setItem('cc_galerie',JSON.stringify(galerieImages));
      renderGalerie();
    };
    reader.readAsDataURL(f);
  });
  toast(files.length + ' image(s) ajoutée(s)','success'); addXP(5);
}
function renderGalerie() {
  const grid = document.getElementById('galerieGrid');
  if (!grid) return;
  if (!galerieImages.length) { grid.innerHTML = '<div style="text-align:center;padding:40px;color:var(--text2);grid-column:1/-1">Aucune image. Glissez des fichiers ici.</div>'; return; }
  grid.innerHTML = galerieImages.map(img=>`<div style="position:relative;border-radius:10px;overflow:hidden;aspect-ratio:1"><img src="${img.src}" style="width:100%;height:100%;object-fit:cover" loading="lazy"><div style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.6);color:white;padding:6px 8px;font-size:11px">${img.name}</div><button onclick="deleteGalerieImg('${img.id}')" style="position:absolute;top:4px;right:4px;background:var(--danger);color:white;border:none;border-radius:6px;padding:4px 8px;cursor:pointer;font-size:11px">✕</button></div>`).join('');
}
function deleteGalerieImg(id) { galerieImages=galerieImages.filter(i=>i.id!=id); localStorage.setItem('cc_galerie',JSON.stringify(galerieImages)); renderGalerie(); }
function clearGalerie() { if(confirm('Effacer toutes les images ?')) { galerieImages=[]; localStorage.setItem('cc_galerie','[]'); renderGalerie(); } }
function galerieFilter(type) { renderGalerie(); }

// ═══ ANALYSEUR FINANCIER ═══
function renderAnalyseur() {
  const rev = financeData.revenus.reduce((a,r)=>a+r.amount,0);
  const dep = financeData.depenses.reduce((a,r)=>a+r.amount,0);
  const marge = rev > 0 ? Math.round(((rev-dep)/rev)*100) : 0;
  if(document.getElementById('anRevAnnuel')) document.getElementById('anRevAnnuel').textContent = formatNum(rev*12);
  if(document.getElementById('anMarge')) document.getElementById('anMarge').textContent = marge+'%';
  if(document.getElementById('anPointMort')) document.getElementById('anPointMort').textContent = formatNum(dep);
  const canvas = document.getElementById('finChart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0,0,canvas.width,canvas.height);
  const maxVal = Math.max(rev,dep,1);
  const barW = 80, gap = 40, startX = 60;
  const h = canvas.height - 60;
  [[rev,'Revenus','#22c55e'],[dep,'Dépenses','#ef4444']].forEach(([val,label,color],i)=>{
    const x = startX + i*(barW+gap);
    const barH = (val/maxVal)*h;
    ctx.fillStyle = color+'33'; ctx.fillRect(x,h-barH+20,barW,barH);
    ctx.fillStyle = color; ctx.fillRect(x,h-barH+20,barW,6);
    ctx.fillStyle = '#999'; ctx.font = '12px Arial'; ctx.textAlign = 'center';
    ctx.fillText(label,x+barW/2,h+40); ctx.fillText(formatNum(val),x+barW/2,h-barH+14);
  });
}
function convertCurrency() {
  const amount = parseInt(document.getElementById('convAmount')?.value)||0;
  if(document.getElementById('convUSD')) document.getElementById('convUSD').textContent = '$' + (amount/605.5).toFixed(2);
  if(document.getElementById('convEUR')) document.getElementById('convEUR').textContent = '€' + (amount/655.957).toFixed(2);
  if(document.getElementById('convNGN')) document.getElementById('convNGN').textContent = '₦' + Math.round(amount*1.49).toLocaleString();
  if(document.getElementById('convGHS')) document.getElementById('convGHS').textContent = '₵' + (amount/60).toFixed(2);
}
async function analyseFinancesIA() {
  const rev = financeData.revenus.reduce((a,r)=>a+r.amount,0);
  const dep = financeData.depenses.reduce((a,r)=>a+r.amount,0);
  const el = document.getElementById('finAnalyseResult');
  el.innerHTML = '<div style="text-align:center;padding:20px">⏳ Analyse en cours...</div>';
  try {
    const res = await fetch('/api/ai/chat',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({message:`Analyse financière complète: revenus totaux ${formatNum(rev)} FCFA, dépenses ${formatNum(dep)} FCFA. Donne une analyse SWOT financière et 3 actions prioritaires pour améliorer la rentabilité.`,context:'Expert financier PME Afrique de l\'Ouest.'})});
    const d = await res.json();
    el.innerHTML = `<div class="glass-card" style="background:var(--bg)">${(d.reply||'').replace(/\n/g,'<br>')}</div>`;
  } catch(e) { el.innerHTML = `<p style="color:red">Erreur: ${e.message}</p>`; }
}
function mlConvert() {
  const amount = parseInt(document.getElementById('mlAmount')?.value)||0;
  const from = document.getElementById('mlFrom')?.value || 'FCFA';
  const rates = {FCFA:1, EUR:655.957, USD:605.5, NGN:0.67};
  const fcfa = amount * rates[from];
  const el = document.getElementById('mlResults');
  if (!el) return;
  el.innerHTML = Object.entries({FCFA:1,EUR:655.957,USD:605.5,NGN:0.67}).filter(([k])=>k!==from).map(([k,r])=>`<div style="display:flex;justify-content:space-between;padding:12px;background:var(--bg);border-radius:10px"><span>${k}</span><span style="font-weight:700;color:var(--accent)">${k==='FCFA'?formatNum(fcfa):(fcfa/r).toFixed(2)}</span></div>`).join('');
}
function setLang(lang) { toast(lang==='fr'?'Français activé':'English mode (coming soon)','info'); }

// ═══ SÉCURITÉ / EXPORT ═══
let activityLogs = JSON.parse(localStorage.getItem('cc_logs')||'[]');
function logActivity(text) {
  activityLogs.unshift({text,time:new Date().toLocaleString('fr-FR'),id:Date.now()});
  if (activityLogs.length > 100) activityLogs = activityLogs.slice(0,100);
  localStorage.setItem('cc_logs',JSON.stringify(activityLogs));
}
function renderActivityLog() {
  const el = document.getElementById('activityLog');
  if (!el) return;
  if (!activityLogs.length) { el.innerHTML='<div style="text-align:center;padding:20px;color:var(--text2)">Aucune activité</div>'; return; }
  el.innerHTML = activityLogs.map(l=>`<div class="activity-item"><div class="activity-dot"></div><div><div class="activity-text">${l.text}</div><div class="activity-time">${l.time}</div></div></div>`).join('');
}
function clearLog() { activityLogs=[]; localStorage.setItem('cc_logs','[]'); renderActivityLog(); }
function exportData() {
  const data = {finance:financeData,tasks:tasksData,events:eventsData,formation:formationData,smart:smartGoals,galerie:galerieImages.map(i=>({...i,src:'[base64]'})),logs:activityLogs,exportDate:new Date().toISOString()};
  const blob = new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='command-center-backup.json'; a.click();
  toast('Données exportées !','success'); logActivity('Export des données effectué');
}
function importData(input) {
  const file = input.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      if (data.finance) { financeData=data.finance; localStorage.setItem('cc_finance',JSON.stringify(financeData)); }
      if (data.tasks) { tasksData=data.tasks; localStorage.setItem('cc_tasks',JSON.stringify(tasksData)); }
      toast('Données importées avec succès !','success'); logActivity('Import des données effectué');
    } catch { toast('Fichier JSON invalide','error'); }
  };
  reader.readAsText(file);
}
function saveIntegration(type) { toast('Intégration "'+type+'" enregistrée !','success'); logActivity('Intégration '+type+' configurée'); }
function testWhatsApp() { const n=document.getElementById('waNumber')?.value||''; if(n) window.open(`https://wa.me/${n.replace(/[^0-9]/g,'')}`,'_blank'); else toast('Entrez un numéro','warning'); }
