async function loadCRM() {
  try {
    const res = await fetch('/api/clients').then(r=>r.json());
    const clients = res.clients || [];
    ['prospect','contacte','negociation','client','fidelise'].forEach(s => {
      document.getElementById('col-'+s).innerHTML = '';
    });
    const counts = {prospect:0,contacte:0,negociation:0,client:0,fidelise:0};
    clients.forEach(c => {
      const col = document.getElementById('col-' + c.status);
      if (col) {
        counts[c.status] = (counts[c.status]||0) + 1;
        col.innerHTML += `<div class="kanban-card"><div style="font-weight:600;margin-bottom:4px">${c.name}</div><div style="font-size:12px;color:var(--text2)">${c.service||''}</div>${c.amount?`<div style="font-size:13px;color:var(--accent);margin-top:6px">${formatNum(c.amount)} FCFA</div>`:''}<div style="display:flex;gap:6px;margin-top:10px"><button class="btn btn-sm btn-secondary" onclick="moveClient('${c.id}','${c.status}')">→</button><button class="btn btn-sm btn-danger" onclick="deleteClient('${c.id}')">✕</button></div></div>`;
      }
    });
    document.getElementById('crmProspects').textContent = counts.prospect||0;
    document.getElementById('crmNego').textContent = counts.negociation||0;
    document.getElementById('crmClients').textContent = counts.client||0;
    document.getElementById('crmFidel').textContent = counts.fidelise||0;
    document.getElementById('statClients').textContent = clients.length;
  } catch(e) { console.log('CRM:', e.message); }
}

