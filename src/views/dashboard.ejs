function toggleManage(id) {
  const panel = document.getElementById('manage-' + id);
  panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
}

async function updateSite(id, template) {
  const name = document.getElementById('edit-name-' + id).value;
  const color = document.getElementById('edit-color-' + id).value;
  const phone = document.getElementById('edit-phone-' + id).value;
  const email = document.getElementById('edit-email-' + id).value;
  const address = document.getElementById('edit-address-' + id).value;
  const desc = document.getElementById('edit-desc-' + id).value;
  const heroFile = document.getElementById('edit-hero-' + id).files[0];
  const aboutFile = document.getElementById('edit-about-' + id).files[0];
  const btn = document.querySelector('#manage-' + id + ' .btn-primary');
  btn.textContent = '⏳ Upload en cours...';
  btn.disabled = true;
  try {
    // Upload images si présentes
    let heroUrl = null, aboutUrl = null;
    if (heroFile) {
      const fd = new FormData();
      fd.append('file', heroFile);
      fd.append('siteId', id);
      fd.append('type', 'hero');
      const r = await fetch('/sites/' + id + '/upload-image', { method:'POST', body: fd });
      const d = await r.json();
      if (d.url) heroUrl = d.url;
    }
    if (aboutFile) {
      const fd = new FormData();
      fd.append('file', aboutFile);
      fd.append('siteId', id);
      fd.append('type', 'about');
      const r = await fetch('/sites/' + id + '/upload-image', { method:'POST', body: fd });
      const d = await r.json();
      if (d.url) aboutUrl = d.url;
    }
    btn.textContent = '⏳ Régénération...';
    const res = await fetch('/sites/' + id + '/update', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ name, color, phone, email, address, desc, template, heroUrl, aboutUrl })
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    toast('✅ Site mis à jour !', 'success');
    loadSites();
  } catch(e) {
    toast('Erreur: ' + e.message, 'error');
  } finally {
    btn.textContent = '🔄 Sauvegarder et régénérer';
    btn.disabled = false;
  }
}

async function previewSite(id) {
  const res = await fetch('/sites/' + id + '/preview');
  const html = await res.text();
  const w = window.open('', '_blank');
  w.document.write(html);
}

async function deleteSite(id) {
  if (!confirm('Supprimer ce site ?')) return;
  await fetch('/api/sites/' + id, {method:'DELETE'});
  loadSites();
  toast('Site supprimé', 'success');
}

