  await fetch('/api/clients/' + id, {method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({status:next})});
  loadCRM();
  toast('Client avancé → ' + next, 'success');
}

async function deleteClient(id) {
