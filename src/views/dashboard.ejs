            <div onclick="document.getElementById('wsColor').value='#059669'" style="width:40px;height:40px;border-radius:10px;background:#059669;cursor:pointer;border:2px solid transparent" onmouseover="this.style.borderColor='white'" onmouseout="this.style.borderColor='transparent'"></div>
            <div onclick="document.getElementById('wsColor').value='#e11d48'" style="width:40px;height:40px;border-radius:10px;background:#e11d48;cursor:pointer;border:2px solid transparent" onmouseover="this.style.borderColor='white'" onmouseout="this.style.borderColor='transparent'"></div>
            <div onclick="document.getElementById('wsColor').value='#d97706'" style="width:40px;height:40px;border-radius:10px;background:#d97706;cursor:pointer;border:2px solid transparent" onmouseover="this.style.borderColor='white'" onmouseout="this.style.borderColor='transparent'"></div>
            <div onclick="document.getElementById('wsColor').value='#0284c7'" style="width:40px;height:40px;border-radius:10px;background:#0284c7;cursor:pointer;border:2px solid transparent" onmouseover="this.style.borderColor='white'" onmouseout="this.style.borderColor='transparent'"></div>
