function renderFormation() {
  if (!formationData) {
    formationData = FORMATION_DATA.map(m=>({...m, items:m.items.map(i=>({label:i,done:false}))}));
  }
  const total = formationData.reduce((a,m)=>a+m.items.length,0);
  const done = formationData.reduce((a,m)=>a+m.items.filter(i=>i.done).length,0);
  document.getElementById('formPct').textContent = Math.round((done/total)*100)+'%';
  document.getElementById('formDone').textContent = done+'/'+total;
  const container = document.getElementById('formationModules');
  container.innerHTML = formationData.map((m,mi)=>`
    <div class="module-card">
      <div class="module-title">${m.title}</div>
      <div class="progress-bar" style="margin-bottom:16px"><div class="progress-fill" style="width:${Math.round((m.items.filter(i=>i.done).length/m.items.length)*100)}%"></div></div>
      ${m.items.map((item,ii)=>`
        <div class="task-item ${item.done?'done':''}" onclick="toggleFormation(${mi},${ii})">
          <div class="task-check">${item.done?'✓':''}</div>
          <span class="task-label">${item.label}</span>
        </div>
      `).join('')}
    </div>
  `).join('');
}

function toggleFormation(mi, ii) {
  formationData[mi].items[ii].done = !formationData[mi].items[ii].done;
  if (formationData[mi].items[ii].done) addXP(15);
  localStorage.setItem('cc_formation', JSON.stringify(formationData));
  renderFormation();
}

