function dfTab(tab, el) {
  document.querySelectorAll('.tabs .tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('dfCreate').style.display = tab === 'history' ? 'none' : 'block';
  document.getElementById('dfHistory').style.display = tab === 'history' ? 'block' : 'none';
  if (tab === 'history') loadQuoteHistory();
}

function dfAddLine() {
  dfLines.push({ name: '', price: 0 });
  renderDFLines();
}

function renderDFLines() {
  const container = document.getElementById('dfLines');
  if (!dfLines.length) { container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--text2)">Aucune prestation. Cliquez "+ Ajouter"</div>'; dfCalc(); return; }
  container.innerHTML = dfLines.map((l,i) => `
    <div style="display:flex;gap:10px;margin-bottom:10px;align-items:center">
      <input class="form-input" style="flex:2" placeholder="Description prestation" value="${l.name}" onchange="dfLines[${i}].name=this.value">
      <input class="form-input" style="flex:1" type="number" placeholder="Prix FCFA" value="${l.price||''}" onchange="dfLines[${i}].price=parseInt(this.value)||0;dfCalc()">
      <button class="btn btn-sm btn-danger" onclick="dfLines.splice(${i},1);renderDFLines()">✕</button>
    </div>
  `).join('');
  dfCalc();
}

function dfCalc() {
  const ht = dfLines.reduce((a,l)=>a+(l.price||0),0);
  const tva = Math.round(ht * 0.18);
  const ttc = ht + tva;
  document.getElementById('dfHT').textContent = formatNum(ht);
  document.getElementById('dfTVA').textContent = formatNum(tva);
  document.getElementById('dfTTC').textContent = formatNum(ttc);
}

