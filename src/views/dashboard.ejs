// FINANCES (localStorage)
// ═══════════════════════════════════════
function addRevenu() {
  const desc = document.getElementById('finRevDesc').value;
  const amount = parseInt(document.getElementById('finRevMontant').value)||0;
  if (!desc||!amount) { toast('Remplissez tous les champs', 'warning'); return; }
  financeData.revenus.push({desc, amount, date: new Date().toLocaleDateString('fr-FR')});
  localStorage.setItem('cc_finance', JSON.stringify(financeData));
  document.getElementById('finRevDesc').value = '';
  document.getElementById('finRevMontant').value = '';
  renderFinance();
  toast('Revenu ajouté !', 'success');
  addXP(5);
}

function addDepense() {
  const desc = document.getElementById('finDepDesc').value;
  const amount = parseInt(document.getElementById('finDepMontant').value)||0;
  if (!desc||!amount) { toast('Remplissez tous les champs', 'warning'); return; }
  financeData.depenses.push({desc, amount, date: new Date().toLocaleDateString('fr-FR')});
  localStorage.setItem('cc_finance', JSON.stringify(financeData));
  document.getElementById('finDepDesc').value = '';
  document.getElementById('finDepMontant').value = '';
  renderFinance();
  toast('Dépense ajoutée !', 'success');
}

function renderFinance() {
  const rev = financeData.revenus.reduce((a,r)=>a+r.amount,0);
  const dep = financeData.depenses.reduce((a,d)=>a+d.amount,0);
  const marge = rev - dep;
  document.getElementById('finRev').textContent = formatNum(rev);
  document.getElementById('finDep').textContent = formatNum(dep);
  document.getElementById('finMarge').textContent = formatNum(marge);
  document.getElementById('statRevenu').textContent = formatNum(rev) + ' FCFA';
  const all = [
    ...financeData.revenus.map(r=>({...r,type:'revenu'})),
    ...financeData.depenses.map(d=>({...d,type:'depense'}))
  ].sort((a,b)=>b.date-a.date);
  const trans = document.getElementById('finTransactions');
  if (!all.length) { trans.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text2)">Aucune transaction</div>'; return; }
  trans.innerHTML = all.map(t=>`<div class="finance-row"><div style="flex:1"><strong>${t.desc}</strong><div style="font-size:12px;color:var(--text2)">${t.date}</div></div><div style="font-weight:700;color:${t.type==='revenu'?'var(--success)':'var(--danger)'}">${t.type==='revenu'?'+':'-'}${formatNum(t.amount)} FCFA</div></div>`).join('');
}

// ═══════════════════════════════════════
// TÂCHES
// ═══════════════════════════════════════
function addTask() {
  const title = document.getElementById('taskTitle').value;
  if (!title) { toast('Entrez un titre', 'warning'); return; }
  tasksData.push({id:Date.now(),title, priority:document.getElementById('taskPriority').value, due:document.getElementById('taskDate').value, done:false});
  localStorage.setItem('cc_tasks', JSON.stringify(tasksData));
  document.getElementById('taskTitle').value = '';
  renderTasks();
  toast('Tâche ajoutée !', 'success');
  addXP(5);
}

let taskFilter = 'all';
function filterTasks(f) { taskFilter = f; renderTasks(); }

function renderTasks() {
  let tasks = tasksData;
  if (taskFilter === 'pending') tasks = tasks.filter(t=>!t.done);
  if (taskFilter === 'done') tasks = tasks.filter(t=>t.done);
  const list = document.getElementById('tasksList');
  if (!tasks.length) { list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text2)">Aucune tâche</div>'; return; }
  const prioColors = {haute:'var(--danger)',moyenne:'var(--warning)',basse:'var(--success)'};
  list.innerHTML = tasks.map(t=>`
    <div style="display:flex;align-items:center;gap:12px;padding:14px;border-bottom:1px solid var(--border)">
      <input type="checkbox" ${t.done?'checked':''} onchange="toggleTask(${t.id})" style="width:18px;height:18px;cursor:pointer">
      <div style="flex:1"><div style="${t.done?'text-decoration:line-through;color:var(--text2)':'font-weight:500'}">${t.title}</div>${t.due?`<div style="font-size:12px;color:var(--text2)">📅 ${t.due}</div>`:''}</div>
      <span style="background:${prioColors[t.priority]}22;color:${prioColors[t.priority]};padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600">${t.priority}</span>
      <button class="btn btn-sm btn-danger" onclick="deleteTask(${t.id})">✕</button>
    </div>
  `).join('');
  document.getElementById('statTaches').textContent = tasksData.filter(t=>!t.done).length;
}

function toggleTask(id) {
  const t = tasksData.find(t=>t.id===id);
  if (t) { t.done = !t.done; if(t.done) addXP(10); }
  localStorage.setItem('cc_tasks', JSON.stringify(tasksData));
  renderTasks();
}

function deleteTask(id) {
  tasksData = tasksData.filter(t=>t.id!==id);
  localStorage.setItem('cc_tasks', JSON.stringify(tasksData));
  renderTasks();
}

// ═══════════════════════════════════════
// AGENDA
// ═══════════════════════════════════════
function addEvent() {
  const title = document.getElementById('evtTitle').value;
  if (!title) { toast('Entrez un titre', 'warning'); return; }
  eventsData.push({id:Date.now(), title, date:document.getElementById('evtDate').value, time:document.getElementById('evtTime').value, desc:document.getElementById('evtDesc').value});
  localStorage.setItem('cc_events', JSON.stringify(eventsData));
  ['evtTitle','evtDate','evtTime','evtDesc'].forEach(id=>document.getElementById(id).value='');
  renderEvents();
  toast('Événement ajouté !', 'success');
}

function renderEvents() {
  const list = document.getElementById('evtList');
  const sorted = [...eventsData].sort((a,b)=>new Date(a.date)-new Date(b.date));
  if (!sorted.length) { list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text2)">Aucun événement</div>'; return; }
  list.innerHTML = sorted.map(e=>`<div style="padding:14px;border-bottom:1px solid var(--border)"><div style="font-weight:600">${e.title}</div><div style="font-size:12px;color:var(--accent);margin:4px 0">${e.date||''} ${e.time||''}</div>${e.desc?`<div style="font-size:13px;color:var(--text2)">${e.desc}</div>`:''}<button class="btn btn-sm btn-danger" style="margin-top:8px" onclick="eventsData=eventsData.filter(ev=>ev.id!==${e.id});localStorage.setItem('cc_events',JSON.stringify(eventsData));renderEvents()">Supprimer</button></div>`).join('');
}

