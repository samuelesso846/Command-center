function renderQuiz() {
  const q = QUIZ_QUESTIONS[quizStep];
  if (!q) { document.getElementById('quizContent').innerHTML = `<div style="text-align:center;padding:20px"><div style="font-size:40px;margin-bottom:12px">${quizScore>=4?'🏆':'👍'}</div><div style="font-size:20px;font-weight:700">${quizScore}/5 bonnes réponses</div><div style="margin-top:12px;color:var(--text2)">${quizScore>=4?'Excellent ! Vous maîtrisez les bases.':'Continuez à apprendre !'}</div><button class="btn btn-primary" style="margin-top:16px" onclick="startQuiz()">Recommencer</button></div>`; addXP(quizScore*10); return; }
  document.getElementById('quizContent').innerHTML = `<div><div style="font-size:12px;color:var(--text2);margin-bottom:8px">Question ${quizStep+1}/5</div><div style="font-weight:700;font-size:15px;margin-bottom:20px">${q.q}</div><div style="display:flex;flex-direction:column;gap:10px">${q.choices.map((c,i)=>`<button class="btn btn-secondary" style="text-align:left" onclick="answerQuiz(${i})">${c}</button>`).join('')}</div></div>`;
}
function answerQuiz(idx) {
  const q = QUIZ_QUESTIONS[quizStep];
  if (idx === q.answer) { quizScore++; toast('✅ Bonne réponse !','success'); }
  else toast(`❌ Mauvaise réponse. C\'était: ${q.choices[q.answer]}`,'error');
  quizStep++; setTimeout(renderQuiz, 1000);
}
