<script>
// ═══════════════════════════════════════
// ÉTAT GLOBAL
// ═══════════════════════════════════════
let currentPage = 'dashboard';
let currentTheme = localStorage.getItem('cc_theme') || 'dark';
let wsStep = 1;
let wsTemplate = '';
let xp = parseInt(localStorage.getItem('cc_xp') || '0');
let level = parseInt(localStorage.getItem('cc_level') || '1');
let dfLines = [];
let financeData = JSON.parse(localStorage.getItem('cc_finance') || '{"revenus":[],"depenses":[]}');
let tasksData = JSON.parse(localStorage.getItem('cc_tasks') || '[]');
let eventsData = JSON.parse(localStorage.getItem('cc_events') || '[]');
let formationData = JSON.parse(localStorage.getItem('cc_formation') || 'null');

// Appliquer thème au démarrage
document.documentElement.setAttribute('data-theme', currentTheme);

// ═══════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════
const pageTitles = {
  dashboard:'📊 Tableau de Bord', sites:'🌐 Créer un Site', devis:'📄 Devis & Factures',
  crm:'👥 CRM Pipeline', social:'📱 Contenus Sociaux', finances:'💰 Finances',
  taches:'✅ Tâches', agenda:'📅 Agenda', prospection:'🎯 Prospection IA',
  formation:'🎓 Formation', gamification:'🏆 Gamification', settings:'⚙️ Paramètres'
};

function goTo(page) {
  currentPage = page;
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + page)?.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.querySelector(`.nav-item[data-page="${page}"]`)?.classList.add('active');
  document.getElementById('pageTitle').textContent = pageTitles[page] || page;
  if (page === 'crm') loadCRM();
  if (page === 'finances') renderFinance();
  if (page === 'taches') renderTasks();
  if (page === 'agenda') renderEvents();
  if (page === 'formation') renderFormation();
  if (page === 'gamification') renderGamification();
  if (page === 'formation') renderFormation();
  if (page === 'securite') renderActivityLog();
  if (page === 'galerie') renderGalerie();
  if (page === 'analyseur') { renderAnalyseur(); convertCurrency(); }
  if (page === 'prediction') { initPrediction(); }
  if (page === 'apprentissage') { renderSmartGoals(); newTip(); }
  if (page === 'chatgpt') {}
  if (page === 'sites') loadSites();
}

// ═══════════════════════════════════════
// SIDEBAR
// ═══════════════════════════════════════
function toggleSidebar() {
  const sb = document.getElementById('sidebar');
  const mn = document.getElementById('main');
  sb.classList.toggle('collapsed');
  mn.classList.toggle('expanded');
  const btn = sb.querySelector('.toggle-btn span');
  if (btn) btn.textContent = sb.classList.contains('collapsed') ? '' : 'Réduire';
}

// ═══════════════════════════════════════
// THÈME
// ═══════════════════════════════════════
const themes = ['dark','light','green','gold'];
function cycleTheme() {
  const idx = (themes.indexOf(currentTheme) + 1) % themes.length;
  setTheme(themes[idx]);
}
function setTheme(t) {
  currentTheme = t;
  document.documentElement.setAttribute('data-theme', t);
  localStorage.setItem('cc_theme', t);
  toast('Thème ' + t + ' appliqué', 'success');
}

// ═══════════════════════════════════════
// TOAST
// ═══════════════════════════════════════
function toast(msg, type = 'info') {
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.textContent = msg;
  document.getElementById('toastContainer').appendChild(el);
  setTimeout(() => el.remove(), 3500);
}

// ═══════════════════════════════════════
// XP
// ═══════════════════════════════════════
function addXP(n) {
  xp += n;
  localStorage.setItem('cc_xp', xp);
  const needed = level * 500;
  if (xp >= needed) { level++; localStorage.setItem('cc_level', level); toast('🎉 Niveau ' + level + ' atteint !', 'success'); }
}

// ═══════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════
async function loadDashboard() {
  try {
    const [clientsRes, quotesRes, tasksRes] = await Promise.all([
      fetch('/api/clients').then(r=>r.json()),
      fetch('/api/quotes').then(r=>r.json()),
      fetch('/api/tasks').then(r=>r.json())
    ]);
    document.getElementById('statClients').textContent = (clientsRes.clients||[]).length;
    document.getElementById('statDevis').textContent = (quotesRes.quotes||[]).filter(q=>q.status==='brouillon').length;
    document.getElementById('statTaches').textContent = (tasksRes.tasks||[]).filter(t=>!t.done).length;
    const rev = financeData.revenus.reduce((a,r)=>a+(r.amount||0),0);
    document.getElementById('statRevenu').textContent = formatNum(rev) + ' FCFA';
  } catch(e) { console.log('Dashboard load:', e.message); }
}

// ═══════════════════════════════════════
// GÉNÉRATEUR DE SITE
// ═══════════════════════════════════════
function selectTpl(el, tpl) {
  document.querySelectorAll('.tpl-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  wsTemplate = tpl;
  toast('Template "' + tpl + '" sélectionné', 'success');
}

function wsNext() {
  if (wsStep === 1 && !wsTemplate) { toast('Sélectionnez un template', 'warning'); return; }
  if (wsStep === 2 && !document.getElementById('wsName').value) { toast('Entrez le nom du business', 'warning'); return; }
  document.getElementById('wsp' + wsStep).classList.remove('active');
  document.getElementById('ws' + wsStep).classList.remove('active');
  document.getElementById('ws' + wsStep).classList.add('done');
  wsStep++;
  document.getElementById('wsp' + wsStep).classList.add('active');
  document.getElementById('ws' + wsStep).classList.add('active');
  if (wsStep === 5) wsGenerate();
}

function wsPrev() {
  document.getElementById('wsp' + wsStep).classList.remove('active');
  document.getElementById('ws' + wsStep).classList.remove('active');
  wsStep--;
  document.getElementById('wsp' + wsStep).classList.add('active');
  document.getElementById('ws' + wsStep).classList.add('active');
  document.getElementById('ws' + (wsStep)).classList.remove('done');
}

async function wsGenerate() {
  const name = document.getElementById('wsName').value;
  const desc = document.getElementById('wsDesc').value;
  const phone = document.getElementById('wsPhone').value;
  const email = document.getElementById('wsEmail').value;
  const address = document.getElementById('wsAddress').value;
  const color = document.getElementById('wsColor').value;

  document.getElementById('wsp' + wsStep).classList.remove('active');
  document.getElementById('ws' + wsStep).classList.add('done');
  wsStep = 5;
  document.getElementById('wsp5').classList.add('active');
  document.getElementById('ws5').classList.add('active');
  document.getElementById('wsLoading').style.display = 'block';
  document.getElementById('wsPreview').style.display = 'none';

  try {
    const formData = new URLSearchParams();
    formData.append('template', wsTemplate);
    formData.append('businessName', name);
    formData.append('niche', wsTemplate);
    formData.append('description', desc);
    formData.append('color', color);
    formData.append('email', email);
    formData.append('phone', phone);
    formData.append('address', address);

    const res = await fetch('/sites/generate', {
      method: 'POST',
      headers: {'Content-Type': 'application/x-www-form-urlencoded'},
      body: formData.toString(),
      redirect: 'follow'
    });

    const html = await res.text();
    window._generatedSite = { name, html, template: wsTemplate, color };
    document.getElementById('wsLoading').style.display = 'none';
    document.getElementById('wsPreview').style.display = 'block';
    document.getElementById('wsPreview').srcdoc = html;

    // Récupérer le slug du dernier site créé
    try {
      const sitesRes = await fetch('/api/sites');
      const sitesData = await sitesRes.json();
      const site = sitesData.sites ? sitesData.sites[0] : null;
      if (site && site.slug) {
        const pubUrl = window.location.origin + '/s/' + site.slug;
        window._generatedSite.slug = site.slug;
        window._generatedSite.id = site.id;
        toast('Site généré ! ' + pubUrl, 'success');
      } else {
        toast('Site généré avec succes !', 'success');
      }
    } catch(e) { toast('Site généré avec succes !', 'success'); }
    addXP(50);
    setTimeout(loadSites, 500);
  } catch(e) {
    document.getElementById('wsLoading').style.display = 'none';
    toast('Erreur generation: ' + e.message, 'error');
  }
}


function wsDownload() {
  if (!window._generatedSite) return toast('Générez d\'abord un site', 'warning');
  const blob = new Blob([window._generatedSite.html], {type:'text/html'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = window._generatedSite.name.replace(/\s+/g,'-') + '.html';
  a.click();
  toast('Site téléchargé !', 'success');
}

async function wsSave() {
  if (!window._generatedSite) return toast('Générez d\'abord un site', 'warning');
  try {
    const res = await fetch('/api/sites', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        site_name: window._generatedSite.name,
        template: window._generatedSite.template,
        colors: {primary: window._generatedSite.color},
        html_output: window._generatedSite.html
      })
    });
    if (res.ok) { toast('Site sauvegardé !', 'success'); loadSites(); }
  } catch(e) { toast('Erreur sauvegarde', 'error'); }
}

async function loadSites() {
  try {
    const res = await fetch('/api/sites').then(r=>r.json());
    const list = document.getElementById('sitesList');
    if (!(res.sites||[]).length) { 
      list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text2)">Aucun site créé</div>'; 
      return; 
    }
    list.innerHTML = res.sites.map(s => {
      const color = (s.colors && s.colors.primary) ? s.colors.primary : '#6366f1';
      const phone = (s.content && s.content.phone) ? s.content.phone : '';
      const email = (s.content && s.content.email) ? s.content.email : '';
      const address = (s.content && s.content.address) ? s.content.address : '';
      const desc = (s.content && s.content.description) ? s.content.description : '';
      const slug = s.slug ? '/s/' + s.slug : '';
      return `
      <div style="border-bottom:1px solid var(--border);padding:14px 0;" id="siterow-${s.id}">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <div>
            <strong>${s.site_name}</strong> 
            <span class="badge badge-info">${s.template}</span>
            ${slug ? '<div style="font-size:.75rem;color:var(--text2);margin-top:2px;">🔗 '+slug+'</div>' : ''}
          </div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <button class="btn btn-sm btn-primary" onclick="toggleManage('${s.id}')">⚙️ Gérer</button>
            <button class="btn btn-sm btn-secondary" onclick="previewSite('${s.id}')">👁️</button>
            ${slug ? '<a href="'+slug+'" target="_blank" class="btn btn-sm btn-secondary">🌐</a>' : ''}
            <button class="btn btn-sm btn-danger" onclick="deleteSite('${s.id}')">🗑️</button>
          </div>
        </div>
