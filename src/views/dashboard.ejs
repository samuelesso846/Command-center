function renderGamification() {
  const levels = [{min:0,max:500,name:'Débutant',badge:'🔰'},{min:500,max:1000,name:'Junior',badge:'🥉'},{min:1000,max:2000,name:'Confirmé',badge:'🥈'},{min:2000,max:3500,name:'Expert',badge:'🥇'},{min:3500,max:99999,name:'Mentor',badge:'👑'}];
  const lvl = levels.findIndex(l=>xp>=l.min&&xp<l.max);
  const current = levels[Math.max(0,lvl)];
  const next = levels[Math.min(lvl+1,levels.length-1)];
  document.getElementById('gamBadge').textContent = current.badge;
  document.getElementById('gamLevel').textContent = `Niveau ${Math.max(1,lvl+1)} — ${current.name}`;
  document.getElementById('gamXP').textContent = xp + ' XP';
  document.getElementById('gamNext').textContent = next.max + ' XP';
  const pct = Math.min(100,((xp-current.min)/(next.min-current.min))*100||0);
  document.getElementById('gamBar').style.width = pct+'%';
  const trophies = [
    {icon:'🌐',name:'Premier Site',desc:'Créer 1 site web',earned:parseInt(localStorage.getItem('cc_sites_created')||'0')>=1},
    {icon:'👥',name:'10 Clients',desc:'Atteindre 10 clients',earned:false},
    {icon:'💰',name:'1M FCFA',desc:'Générer 1M FCFA',earned:financeData.revenus.reduce((a,r)=>a+r.amount,0)>=1000000},
    {icon:'📱',name:'Influenceur',desc:'Générer 50 posts',earned:false},
    {icon:'🎓',name:'Diplômé',desc:'Compléter la formation',earned:false},
    {icon:'👑',name:'Expert',desc:'Atteindre niveau Expert',earned:xp>=2000}
  ];
  document.getElementById('gamTrophies').innerHTML = trophies.map(t=>`
    <div class="glass-card" style="text-align:center;opacity:${t.earned?1:0.4}">
      <div style="font-size:40px;margin-bottom:8px">${t.icon}</div>
      <div style="font-weight:700;font-size:13px">${t.name}</div>
      <div style="font-size:11px;color:var(--text2);margin-top:4px">${t.desc}</div>
      ${t.earned?'<div style="color:var(--success);font-size:11px;margin-top:6px">✅ Débloqué</div>':'<div style="color:var(--text2);font-size:11px;margin-top:6px">🔒 Verrouillé</div>'}
