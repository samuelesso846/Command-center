// ═══ GÉNÉRATEUR LOGO ═══
function generateLogo() {
  const canvas = document.getElementById('logoCanvas');
  const ctx = canvas.getContext('2d');
  const name = document.getElementById('logoName').value || 'LOGO';
  const slogan = document.getElementById('logoSlogan').value;
  const color = document.getElementById('logoColor').value;
  const style = document.getElementById('logoStyle').value;
  ctx.clearRect(0, 0, 400, 200);
  const grad = ctx.createLinearGradient(0,0,400,0);
  grad.addColorStop(0, color); grad.addColorStop(1, color+'99');
  ctx.fillStyle = '#f8f9fc'; ctx.fillRect(0,0,400,200);
  if (style === 'icon' || style === 'bold') {
    ctx.fillStyle = color; ctx.beginPath(); ctx.arc(70,100,45,0,Math.PI*2); ctx.fill();
    ctx.fillStyle = 'white'; ctx.font = 'bold 36px Arial'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText(name[0].toUpperCase(), 70, 100);
    ctx.fillStyle = color; ctx.font = 'bold 32px Arial'; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
    ctx.fillText(name.toUpperCase(), 130, 90);
    if (slogan) { ctx.fillStyle = '#666'; ctx.font = '14px Arial'; ctx.fillText(slogan, 130, 120); }
  } else if (style === 'minimal') {
    ctx.strokeStyle = color; ctx.lineWidth = 3; ctx.strokeRect(20,20,360,160);
    ctx.fillStyle = color; ctx.font = 'bold 48px Georgia'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText(name, 200, 90);
    if (slogan) { ctx.fillStyle = '#666'; ctx.font = '14px Arial'; ctx.fillText(slogan, 200, 140); }
  } else {
    ctx.fillStyle = grad; ctx.font = 'bold 52px Arial'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText(name.toUpperCase(), 200, 90);
    if (slogan) { ctx.fillStyle = '#888'; ctx.font = '15px Arial'; ctx.fillText(slogan, 200, 140); }
  }
  toast('Logo généré !', 'success'); addXP(10);
}
function downloadLogo() {
  generateLogo();
  const a = document.createElement('a');
  a.download = 'logo.png';
  a.href = document.getElementById('logoCanvas').toDataURL('image/png');
  a.click(); toast('Logo téléchargé !', 'success');
}

