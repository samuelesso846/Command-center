<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mes Sites — Command Center</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'Poppins',sans-serif; background:#0f172a; color:#fff; min-height:100vh; padding:24px; }
.header { display:flex; align-items:center; justify-content:space-between; margin-bottom:32px; }
.header h1 { font-size:1.4rem; font-weight:700; }
.btn-new { background:#6366f1; color:#fff; padding:10px 20px; border-radius:10px; text-decoration:none; font-weight:600; font-size:.9rem; }
.sites-grid { display:flex; flex-direction:column; gap:16px; }
.site-card { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:20px; }
.site-card-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
.site-info h3 { font-size:1rem; font-weight:600; margin-bottom:4px; }
.site-info .badge { display:inline-block; background:rgba(99,102,241,0.2); color:#818cf8; padding:2px 10px; border-radius:50px; font-size:.75rem; font-weight:600; }
.site-url { font-size:.8rem; color:#64748b; margin-top:4px; word-break:break-all; }
.site-actions { display:flex; gap:8px; flex-wrap:wrap; }
.btn { padding:8px 14px; border-radius:8px; font-size:.8rem; font-weight:600; cursor:pointer; border:none; text-decoration:none; display:inline-flex; align-items:center; gap:6px; }
.btn-manage { background:#6366f1; color:#fff; }
.btn-preview { background:rgba(255,255,255,0.08); color:#fff; }
.btn-delete { background:rgba(239,68,68,0.15); color:#f87171; }

/* PANEL GESTION */
.manage-panel { display:none; margin-top:16px; border-top:1px solid rgba(255,255,255,0.08); padding-top:16px; }
.manage-panel.open { display:block; }
.form-group { margin-bottom:14px; }
.form-label { display:block; font-size:.8rem; color:#94a3b8; margin-bottom:6px; font-weight:500; }
.form-input { width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); border-radius:8px; padding:10px 14px; color:#fff; font-family:'Poppins',sans-serif; font-size:.9rem; }
.form-input:focus { outline:none; border-color:#6366f1; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.btn-save { width:100%; background:#6366f1; color:#fff; padding:12px; border-radius:10px; font-weight:600; font-size:.95rem; border:none; cursor:pointer; margin-top:8px; }
.btn-save:active { background:#4f46e5; }
.toast { position:fixed; bottom:24px; left:50%; transform:translateX(-50%); background:#22c55e; color:#fff; padding:12px 24px; border-radius:10px; font-weight:600; font-size:.9rem; display:none; z-index:999; }
.empty { text-align:center; padding:60px 20px; color:#475569; }
.empty p { margin-bottom:20px; }
</style>
</head>
<body>

<div class="header">
  <div>
    <a href="/dashboard" style="color:#64748b;text-decoration:none;font-size:.85rem;">← Dashboard</a>
    <h1 style="margin-top:4px;">🌐 Mes Sites</h1>
  </div>
  <a href="/sites/new" class="btn-new">+ Nouveau site</a>
</div>

<% if (!sites || sites.length === 0) { %>
<div class="empty">
  <p style="font-size:3rem;">🌐</p>
  <p>Aucun site créé pour le moment</p>
  <a href="/sites/new" class="btn-new">Créer mon premier site</a>
</div>
<% } else { %>
<div class="sites-grid">
<% sites.forEach((s, idx) => { %>
  <div class="site-card" id="card-<%= s.id %>">
    <div class="site-card-header">
      <div class="site-info">
        <h3><%= s.site_name %></h3>
        <span class="badge"><%= s.template %></span>
        <% if (s.slug) { %>
        <div class="site-url">🔗 /s/<%= s.slug %></div>
        <% } %>
      </div>
    </div>
    <div class="site-actions">
      <button class="btn btn-manage" onclick="togglePanel('<%= s.id %>')">⚙️ Gérer</button>
      <a href="/sites/<%= s.id %>/preview" target="_blank" class="btn btn-preview">👁 Aperçu</a>
      <% if (s.slug) { %>
      <a href="/s/<%= s.slug %>" target="_blank" class="btn btn-preview">🌐 Live</a>
      <% } %>
      <a href="/sites/<%= s.id %>/download" class="btn btn-preview">⬇️ HTML</a>
      <button class="btn btn-delete" onclick="deleteSite('<%= s.id %>', '<%= s.site_name %>')">🗑</button>
    </div>

    <!-- PANEL GESTION -->
    <div class="manage-panel" id="panel-<%= s.id %>">
      <p style="font-size:.85rem;color:#94a3b8;margin-bottom:16px;font-weight:600;">✏️ Modifier les informations</p>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Nom du business</label>
          <input class="form-input" id="name-<%= s.id %>" value="<%= s.site_name %>" placeholder="Nom">
        </div>
        <div class="form-group">
          <label class="form-label">Couleur principale</label>
          <input class="form-input" type="color" id="color-<%= s.id %>" value="<%= (s.colors && s.colors.primary) ? s.colors.primary : '#6366f1' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Téléphone</label>
          <input class="form-input" id="phone-<%= s.id %>" value="<%= (s.content && s.content.phone) ? s.content.phone : '' %>" placeholder="+228...">
        </div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input class="form-input" id="email-<%= s.id %>" value="<%= (s.content && s.content.email) ? s.content.email : '' %>" placeholder="email@...">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Adresse</label>
        <input class="form-input" id="address-<%= s.id %>" value="<%= (s.content && s.content.address) ? s.content.address : '' %>" placeholder="Lomé, Togo">
      </div>
      <div class="form-group">
        <label class="form-label">Description (pour régénérer le contenu)</label>
        <textarea class="form-input" id="desc-<%= s.id %>" rows="3" placeholder="Décrivez le business..."><%= (s.content && s.content.description) ? s.content.description : '' %></textarea>
      </div>
      <button class="btn-save" onclick="saveSite('<%= s.id %>', '<%= s.template %>')">
        🔄 Sauvegarder et régénérer le site
      </button>
    </div>
  </div>
<% }) %>
</div>
<% } %>

<div class="toast" id="toast"></div>

<script>
function togglePanel(id) {
  const panel = document.getElementById('panel-' + id);
  panel.classList.toggle('open');
}

function toast(msg, type) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = type === 'error' ? '#ef4444' : '#22c55e';
  t.style.display = 'block';
  setTimeout(() => t.style.display = 'none', 3000);
}

async function saveSite(id, template) {
  const name = document.getElementById('name-' + id).value;
  const color = document.getElementById('color-' + id).value;
  const phone = document.getElementById('phone-' + id).value;
  const email = document.getElementById('email-' + id).value;
  const address = document.getElementById('address-' + id).value;
  const desc = document.getElementById('desc-' + id).value;

  const btn = document.querySelector('#panel-' + id + ' .btn-save');
  btn.textContent = '⏳ Régénération en cours...';
  btn.disabled = true;

  try {
    const res = await fetch('/sites/' + id + '/update', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ name, color, phone, email, address, desc, template })
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    toast('✅ Site mis à jour avec succès !');
    setTimeout(() => location.reload(), 1500);
  } catch(e) {
    toast('Erreur: ' + e.message, 'error');
  } finally {
    btn.textContent = '🔄 Sauvegarder et régénérer le site';
    btn.disabled = false;
  }
}

async function deleteSite(id, name) {
  if (!confirm('Supprimer "' + name + '" ?')) return;
  await fetch('/api/sites/' + id, { method: 'DELETE' });
  document.getElementById('card-' + id).remove();
  toast('Site supprimé');
}
</script>
</body>
</html>